{
    "name": "@bric/rex-search-mirror",
    "version": "0.0.1",
    "description": "REX module mirrors results from search engines.",
    "keywords": [
        "extension",
        "rex"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "homepage": "https://github.com/bric-digital/rex-search-mirror",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-search-mirror/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-search-mirror.git"
    },
    "exports": {
        "./browser": "./src/browser.mts",
        "./service-worker": "./src/service-worker.mts",
        "./sites/browser/google": "./src/sites/google.mts",
        "./sites/browser/bing": "./src/sites/bing.mts",
        "./sites/browser/duckduckgo": "./src/sites/duckduckgo.mts",
        "./sites/service-worker/google": "./src/sites/google_worker.mts",
        "./sites/service-worker/bing": "./src/sites/bing_worker.mts",
        "./sites/service-worker/duckduckgo": "./src/sites/duckduckgo_worker.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
        "test:ci": "playwright test --reporter=dot",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "playwright test specs/"
    },
    "dependencies": {
        "@bric/rex-core": "github:bric-digital/rex-core",
        "install": "^0.13.0",
        "jquery": "^3.7.1"
    }
}
